{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "currency": { "type": "string" },
        "dateFormat": { "type": "string" },
        "locale": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["uid", "name", "email", "currency"]
    },
    "Category": {
      "title": "Category",
      "description": "Income or Expense Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "uid", "name", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A single financial transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "date": { "type": "string" },
        "categoryId": { "type": "string" },
        "amount": { "type": "number" },
        "comment": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "uid", "date", "categoryId", "amount", "type"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Budget limit for a given category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "categoryId": { "type": "string" },
        "limit": { "type": "number" },
        "period": { "type": "string", "enum": ["monthly", "yearly"] },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "uid", "categoryId", "limit", "period"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Recurring payments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "categoryId": { "type": "string" },
        "frequency": { "type": "string" },
        "deductionDate": { "type": "number" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "uid", "name", "amount", "categoryId", "frequency", "deductionDate"]
    },
    "CreditCard": {
      "title": "CreditCard",
      "description": "User's credit card details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "dueDate": { "type": "number" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      },
      "required": ["id", "uid", "name", "dueDate"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories for user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transactions for user"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": { "$ref": "#/entities/Budget" },
      "description": "Budgets for user"
    },
    "/users/{userId}/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "#/entities/Subscription" },
      "description": "Subscriptions for user"
    },
    "/users/{userId}/creditCards/{creditCardId}": {
      "schema": { "$ref": "#/entities/CreditCard" },
      "description": "Credit cards for user"
    }
  }
}
