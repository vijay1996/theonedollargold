rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation for UserProfile
    function isValidUserProfile(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'name', 'currency']) &&
             data.uid == userId &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.currency is string && data.currency.size() <= 10;
    }

    // Validation for Category
    function isValidCategory(data, userId) {
      return data.keys().hasAll(['id', 'uid', 'name', 'type']) &&
             data.uid == userId &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type is string && (data.type == 'income' || data.type == 'expense');
    }

    // Validation for Transaction
    function isValidTransaction(data, userId) {
      return data.keys().hasAll(['id', 'uid', 'date', 'categoryId', 'amount', 'type']) &&
             data.uid == userId &&
             data.id is string && data.id.size() <= 128 &&
             data.date is string && data.date.size() <= 30 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.amount is number &&
             data.type is string && (data.type == 'income' || data.type == 'expense');
    }

    // Validation for Budget
    function isValidBudget(data, userId) {
      return data.keys().hasAll(['id', 'uid', 'categoryId', 'limit', 'period']) &&
             data.uid == userId &&
             data.id is string && data.id.size() <= 128 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.limit is number &&
             data.period is string && (data.period == 'monthly' || data.period == 'yearly');
    }

    // Validation for Subscription
    function isValidSubscription(data, userId) {
      return data.keys().hasAll(['id', 'uid', 'name', 'amount', 'categoryId', 'frequency', 'deductionDate']) &&
             data.uid == userId &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.amount is number &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.frequency is string && data.frequency.size() <= 50 &&
             data.deductionDate is number;
    }

    // Validation for CreditCard
    function isValidCreditCard(data, userId) {
      return data.keys().hasAll(['id', 'uid', 'name', 'dueDate']) &&
             data.uid == userId &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.dueDate is number;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || (isSignedIn() && existing().uid == request.auth.uid);
      allow list: if isSignedIn() && existing().uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUserProfile(incoming(), userId);
      allow update: if isOwner(userId) && isValidUserProfile(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'currency', 'dateFormat', 'locale', 'updatedAt']);
      allow delete: if isOwner(userId);

      match /categories/{categoryId} {
        allow get: if isOwner(userId) && isValidId(categoryId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(categoryId);
      }

      match /transactions/{transactionId} {
        allow get: if isOwner(userId) && isValidId(transactionId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['date', 'categoryId', 'amount', 'type', 'comment', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(transactionId);
      }

      match /budgets/{budgetId} {
        allow get: if isOwner(userId) && isValidId(budgetId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(budgetId) && isValidBudget(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['categoryId', 'limit', 'period', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(budgetId);
      }

      match /subscriptions/{subscriptionId} {
        allow get: if isOwner(userId) && isValidId(subscriptionId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(subscriptionId) && isValidSubscription(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(subscriptionId) && isValidSubscription(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'categoryId', 'frequency', 'deductionDate', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(subscriptionId);
      }

      match /creditCards/{creditCardId} {
        allow get: if isOwner(userId) && isValidId(creditCardId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(creditCardId) && isValidCreditCard(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(creditCardId) && isValidCreditCard(incoming(), userId) && incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'dueDate', 'updatedAt']);
        allow delete: if isOwner(userId) && isValidId(creditCardId);
      }
    }
  }
}
